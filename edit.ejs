<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Form Kategori</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body><%- include('../partials/_navbar') %>
    <div class="container mt-5">
        <a href="/kategori/" class="btn btn-sm btn-primary mb-3">Back</a>

        <div class="card">
            <div class="card-header bg-primary text-white">
                Form Edit Kategori
            </div>

        <div class="card-body">
            <form action="/kategori/update/<%= id %>" method="POST">

                <div class="mb-3">
                    <label class="form-label">Nama Kategori</label>
                    <input type="text" name="nama_kategori" value="<%= nama_kategori %>" class="form-control" required>
                </div>

                <button type="submit" class="btn btn-success">
                    Update
                </button>

                <a href="/kategori" class="btn btn-secondary">
                    Kembali
                </a>

            </form>
        </div>

    </div>
</div>

</body>
</html>